# Zammad environment variables — Docker / Container Apps variants.
# See https://docs.zammad.org/en/latest/appendix/environment-variables.html for the
# authoritative list. Values below are documentation only; runtime values come from
# Container Apps secret refs (which in turn pull from Azure Key Vault `kv-plug-zammad`).

# -----------------------------------------------------------------------------
# Postgres (Azure DB for PostgreSQL Flexible Server: pg-plug-zammad)
# Note: the Docker variant uses POSTGRES_PASS (not POSTGRES_PASSWORD).
# -----------------------------------------------------------------------------
POSTGRES_HOST=pg-plug-zammad.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=zammad_production
POSTGRES_USER=zammad
POSTGRES_PASS=__from-keyvault__

# -----------------------------------------------------------------------------
# Redis (Azure Cache for Redis: cache-plug-zammad). TLS required.
# -----------------------------------------------------------------------------
REDIS_URL=rediss://:__from-keyvault__@cache-plug-zammad.redis.cache.windows.net:6380/0

# -----------------------------------------------------------------------------
# Memcached (in-cluster: ca-plug-zammad-memcached). Required for containerised
# Zammad — shares cache across replicas. Default is zammad-memcached:11211.
# -----------------------------------------------------------------------------
MEMCACHE_SERVERS=ca-plug-zammad-memcached:11211

# -----------------------------------------------------------------------------
# FQDN
# -----------------------------------------------------------------------------
ZAMMAD_FQDN=operations.plugport.no
ZAMMAD_WEB_CONCURRENCY=4
ZAMMAD_RAILS_TRUSTED_PROXIES=10.40.0.0/16

# -----------------------------------------------------------------------------
# NOT env vars — configured via Rails console post-deploy.
# See docs/features/post-install.md
# -----------------------------------------------------------------------------
# Elasticsearch / OpenSearch URL → Setting.set('es_url', 'http://ca-plug-zammad-opensearch:9200')
# Storage provider → Setting.set('storage_provider', 'File')
# FQDN at app level → Setting.set('fqdn', 'operations.plugport.no')
# HTTPS scheme → Setting.set('http_type', 'https')

# -----------------------------------------------------------------------------
# NOT env vars — configured in the Zammad admin UI.
# Settings → Security → Third Party Applications → Microsoft (Office 365)
# Source the secret from kv-plug-zammad/entra-zammad-client-secret at setup time.
# -----------------------------------------------------------------------------
# Microsoft Entra App (client) ID
# Microsoft Entra Tenant ID
# Microsoft Entra Client Secret  (paste from Key Vault)

# -----------------------------------------------------------------------------
# SMTP — TBD. Decision tracked as Linear issue in the Zammad project.
# Once decided, populate via Key Vault and Container Apps secret refs.
# Variables Zammad would consume (set via admin UI Channels → Email):
#   smtp_host, smtp_port, smtp_user, smtp_password, smtp_domain, smtp_starttls_auto
# -----------------------------------------------------------------------------
